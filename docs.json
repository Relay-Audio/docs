              "api-reference/annotations/create-annotations-bulk",
              "api-reference/annotations/update-annotation",
              "api-reference/annotations/delete-annotation",
              "api-reference/annotations/export-label-studio"
            ]
          },
          {
            "group": "Training Jobs",
            "pages": [
              "api-reference/training/create-training-job",
              "api-reference/training/list-training-jobs",
              "api-reference/training/get-training-job",
              "api-reference/training/cancel-training-job"
