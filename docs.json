{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Relay",
  "colors": {
    "primary": "#6366F1",
    "light": "#818CF8",
    "dark": "#4F46E5"
  },
  "favicon": "/favicon.svg",
  "openapi": "openapi.yaml",
  "api": {
    "baseUrl": "https://api.relay.ai",
    "auth": {
      "method": "key",
      "name": "X-API-Key"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/authentication",
              "guides/uploading-audio",
              "guides/creating-annotations",
              "guides/training-models",
              "guides/running-inference",
              "guides/understanding-results"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/datasets",
              "concepts/annotation-sets",
              "concepts/artifact-types",
              "concepts/models"
            ]
          },
          {
            "group": "SDKs",
            "pages": [
              "sdks/python",
              "sdks/typescript",
              "sdks/curl"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Authentication",
            "pages": [
              {
                "openapi": "GET /api/v1/auth/me"
              },
              {
                "openapi": "GET /api/v1/auth/api-keys"
              },
              {
                "openapi": "POST /api/v1/auth/api-keys"
              },
              {
                "openapi": "DELETE /api/v1/auth/api-keys/{key_id}"
              }
            ]
          },
          {
            "group": "Datasets",
            "pages": [
              {
                "openapi": "GET /api/v1/datasets"
              },
              {
                "openapi": "POST /api/v1/datasets"
              },
              {
                "openapi": "GET /api/v1/datasets/{dataset_id}"
              },
              {
                "openapi": "PATCH /api/v1/datasets/{dataset_id}"
              },
              {
                "openapi": "DELETE /api/v1/datasets/{dataset_id}"
              }
            ]
          },
          {
            "group": "Audio Files",
            "pages": [
              {
                "openapi": "POST /api/v1/datasets/{dataset_id}/audio/upload-url"
              },
              {
                "openapi": "POST /api/v1/datasets/{dataset_id}/audio/confirm"
              },
              {
                "openapi": "GET /api/v1/datasets/{dataset_id}/audio"
              },
              {
                "openapi": "GET /api/v1/datasets/{dataset_id}/audio/{audio_id}"
              },
              {
                "openapi": "DELETE /api/v1/datasets/{dataset_id}/audio/{audio_id}"
              },
              {
                "openapi": "GET /api/v1/datasets/{dataset_id}/audio/{audio_id}/download-url"
              }
            ]
          },
          {
            "group": "Annotations",
            "pages": [
              {
                "openapi": "POST /api/v1/datasets/{dataset_id}/annotation-sets"
              },
              {
                "openapi": "GET /api/v1/datasets/{dataset_id}/annotation-sets"
              },
              {
                "openapi": "GET /api/v1/datasets/{dataset_id}/annotation-sets/{annotation_set_id}"
              },
              {
                "openapi": "DELETE /api/v1/datasets/{dataset_id}/annotation-sets/{annotation_set_id}"
              },
              {
                "openapi": "POST /api/v1/datasets/{dataset_id}/annotation-sets/{annotation_set_id}/publish"
              },
              {
                "openapi": "POST /api/v1/datasets/{dataset_id}/annotation-sets/{annotation_set_id}/annotations"
              },
              {
                "openapi": "GET /api/v1/datasets/{dataset_id}/annotation-sets/{annotation_set_id}/annotations"
              },
              {
                "openapi": "POST /api/v1/datasets/{dataset_id}/annotation-sets/{annotation_set_id}/annotations/bulk"
              },
              {
                "openapi": "PATCH /api/v1/datasets/{dataset_id}/annotation-sets/{annotation_set_id}/annotations/{annotation_id}"
              },
              {
                "openapi": "DELETE /api/v1/datasets/{dataset_id}/annotation-sets/{annotation_set_id}/annotations/{annotation_id}"
              },
              {
                "openapi": "GET /api/v1/datasets/{dataset_id}/annotation-sets/{annotation_set_id}/export/label-studio"
              }
            ]
          },
          {
            "group": "Training",
            "pages": [
              {
                "openapi": "POST /api/v1/training-jobs"
              },
              {
                "openapi": "GET /api/v1/training-jobs"
              },
              {
                "openapi": "GET /api/v1/training-jobs/{job_id}"
              },
              {
                "openapi": "DELETE /api/v1/training-jobs/{job_id}"
              },
              {
                "openapi": "GET /api/v1/models"
              },
              {
                "openapi": "GET /api/v1/models/{model_id}"
              },
              {
                "openapi": "PATCH /api/v1/models/{model_id}"
              },
              {
                "openapi": "DELETE /api/v1/models/{model_id}"
              }
            ]
          },
          {
            "group": "Inference",
            "pages": [
              {
                "openapi": "POST /api/v1/inference-jobs"
              },
              {
                "openapi": "GET /api/v1/inference-jobs"
              },
              {
                "openapi": "GET /api/v1/inference-jobs/{job_id}"
              },
              {
                "openapi": "DELETE /api/v1/inference-jobs/{job_id}"
              },
              {
                "openapi": "GET /api/v1/inference-jobs/{job_id}/files"
              },
              {
                "openapi": "GET /api/v1/inference-jobs/{job_id}/files/{file_id}"
              },
              {
                "openapi": "POST /api/v1/inference-jobs/{job_id}/files/upload-url"
              },
              {
                "openapi": "POST /api/v1/inference-jobs/{job_id}/files/confirm"
              },
              {
                "openapi": "GET /api/v1/inference-jobs/{job_id}/files/{file_id}/download-url"
              }
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "API Reference",
          "href": "/api-reference/introduction",
          "icon": "code"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/relay-ai",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@relay.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.relay.ai"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "cursor"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/relay-ai",
      "x": "https://x.com/relay_ai",
      "linkedin": "https://linkedin.com/company/relay-ai"
    }
  }
}
