              "api-reference/datasets/update-dataset",
              "api-reference/datasets/delete-dataset"
            ]
          },
          {
            "group": "Audio Files",
            "pages": [
              "api-reference/audio/get-upload-url",
              "api-reference/audio/confirm-upload",
              "api-reference/audio/list-audio-files",
