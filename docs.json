    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "cursor"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/Relay-Audio",
      "x": "https://x.com/relay_ai",
      "linkedin": "https://linkedin.com/company/relay-ai"
    }
  }
