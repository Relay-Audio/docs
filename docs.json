              "api-reference/inference-files/get-file-download-url"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Guides",
          "href": "/quickstart",
          "icon": "book"
        },
        {
          "anchor": "API Reference",
          "href": "/api-reference/introduction",
          "icon": "code"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/Relay-Audio",
          "icon": "github"
        }
