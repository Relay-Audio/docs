{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Relay",
  "colors": {
    "primary": "#D4650F",
    "light": "#E8883A",
    "dark": "#B84A0A"
  },
  "favicon": "/favicon.png",
  "fonts": {
    "heading": {
      "family": "Plus Jakarta Sans",
      "weight": 700
    },
    "body": {
      "family": "Inter",
      "weight": 400
    }
  },
  "openapi": "openapi.yaml",
  "api": {
    "baseUrl": "https://api.relayai.dev",
    "auth": {
      "method": "key",
      "name": "X-API-Key"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/authentication",
              "guides/uploading-audio",
              "guides/creating-annotations",
              "guides/training-models",
              "guides/running-inference",
              "guides/understanding-results"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/datasets",
              "concepts/annotation-sets",
              "concepts/artifact-types",
              "concepts/models"
            ]
          },
          {
            "group": "SDKs",
            "pages": [
              "sdks/python",
              "sdks/typescript",
              "sdks/curl"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
